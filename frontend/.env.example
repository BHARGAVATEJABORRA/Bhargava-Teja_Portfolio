NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000
AUTH_URL=http://127.0.0.1:3000
AUTH_TRUST_HOST=true
NEXT_PUBLIC_GA_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify
# Spotify refresh tokens come from the authorization-code flow:
# 1. Add the redirect URI above in the Spotify dashboard.
# 2. Visit /api/auth/signin locally.
# 3. Approve access; the callback saves this value in .env.local for local dev.
# 4. Copy the value into production env vars before release.
SPOTIFY_REFRESH_TOKEN=
# Weather now uses Open-Meteo client-side — free, no API key needed.
# Coordinates come from identity.controlCenter.weatherLat/weatherLng in portfolio-content.ts.

# Production (GitHub Pages) Spotify endpoint — the deployed serverless function
# from spotify-endpoint/README.md. Leave empty in local dev (/api/spotify is used).
NEXT_PUBLIC_SPOTIFY_ENDPOINT=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Admin passkey gate (Touch ID / WebAuthn) ---
# Open the app at http://localhost:3000 in dev (NOT 127.0.0.1 — bare IPs are rejected by passkeys).
# In production set this to your https origin, e.g. https://admin.example.com
WEBAUTHN_ORIGIN=http://localhost:3000
# RP ID defaults to the hostname of WEBAUTHN_ORIGIN (localhost in dev). Override only if needed.
WEBAUTHN_RP_ID=
# Secret used to sign the admin session cookie. Set a long random value in production.
ADMIN_SESSION_SECRET=
# Fallback passcode for when Touch ID / passkeys aren't usable (e.g. cross-device QR on localhost).
# Defaults to "admin1234" in dev if unset. Set a strong value before production.
ADMIN_PASSCODE=

# --- Admin content database (Prisma + SQLite) ---
# Put this in frontend/.env (NOT .env.local — the Prisma CLI only reads .env).
# The path is relative to prisma/schema.prisma. Setup:
#   npx prisma migrate dev   # create/update the database
#   npx prisma db seed       # seed from content/portfolio-content.ts (idempotent)
DATABASE_URL="file:./dev.db"

CONTACT_TO_EMAIL=bhargavateja.borra@gmail.com
# Optional production delivery hook. Point this at Resend, Formspree, Make, Zapier, or your own API endpoint.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=

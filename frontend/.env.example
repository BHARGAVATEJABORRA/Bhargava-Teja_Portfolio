NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000
AUTH_URL=http://127.0.0.1:3000
AUTH_TRUST_HOST=true
NEXT_PUBLIC_GA_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify
# Spotify refresh tokens come from the authorization-code flow:
# 1. Add the redirect URI above in the Spotify dashboard.
# 2. Visit /api/auth/signin locally.
# 3. Approve access; the callback saves this value in .env.local for local dev.
# 4. Copy the value into production env vars before release.
SPOTIFY_REFRESH_TOKEN=
# Weather (control center). Free key from https://openweathermap.org/api (Current Weather Data).
# Coordinates come from identity.controlCenter.weatherLat/weatherLng in portfolio-content.ts.
OPENWEATHER_API_KEY=
NEXT_PUBLIC_OPENWEATHER_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CONTACT_TO_EMAIL=bhargavateja.borra@gmail.com
# Optional production delivery hook. Point this at Resend, Formspree, Make, Zapier, or your own API endpoint.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=
